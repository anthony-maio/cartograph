{
  "name": "opencodewiki",
  "version": "1.0.0",
  "description": "Generate intelligent wiki documentation from any Git repo. Targeted context for LLMs.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "opencodewiki": "./dist/cli.cjs"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "esbuild src/cli.ts --bundle --platform=node --format=cjs --outfile=dist/cli.cjs --banner:js=\"#!/usr/bin/env node\" --external:simple-git --external:@google/genai --external:openai",
    "start": "node dist/cli.cjs",
    "check": "tsc"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "openai": "^6.27.0",
    "ora": "^8.1.0",
    "simple-git": "^3.33.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "20.19.27",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.5",
    "typescript": "5.6.3"
  }
}
