{
  "name": "@anthony-maio/cartograph",
  "version": "1.1.4",
  "mcpName": "io.github.anthony-maio/cartograph",
  "description": "MCP server + CLI for intelligent codebase analysis. Scores files by importance, maps dependencies, provides targeted context for AI agents.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anthony-maio/cartograph.git"
  },
  "homepage": "https://github.com/anthony-maio/cartograph#readme",
  "bugs": {
    "url": "https://github.com/anthony-maio/cartograph/issues"
  },
  "keywords": [
    "ai-agents",
    "cartograph",
    "cli",
    "code-analysis",
    "mcp",
    "repository-analysis"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "bin": {
    "cartograph": "./dist/cli.cjs"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:mcp": "tsx src/mcp.ts",
    "build": "esbuild src/cli.ts --bundle --platform=node --format=cjs --outfile=dist/cli.cjs --banner:js=\"#!/usr/bin/env node\" --external:simple-git --external:@google/genai --external:openai && esbuild src/mcp.ts --bundle --platform=node --format=cjs --outfile=dist/mcp.cjs --external:simple-git --external:@google/genai --external:openai --external:@modelcontextprotocol/sdk",
    "start": "node dist/cli.cjs",
    "start:mcp": "node dist/mcp.cjs",
    "check": "tsc",
    "pack:smoke": "node scripts/pack-smoke.mjs",
    "benchmark:task-packets": "node scripts/task-packet-benchmark.mjs",
    "release:check": "npm test && npm run check && npm run build && npm run pack:smoke",
    "test": "node --import tsx --test",
    "test:watch": "node --import tsx --test --watch"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "openai": "^6.33.0",
    "ora": "^8.1.0",
    "simple-git": "^3.33.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "20.19.27",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.5",
    "typescript": "5.6.3"
  },
  "overrides": {
    "path-to-regexp": "^8.4.0"
  }
}
